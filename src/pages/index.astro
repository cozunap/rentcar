---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Luxury Rental Home Experience">
<!-- Top Navigation -->
<nav id="main-header" class="fixed top-0 w-full z-50 border-b border-white/10 backdrop-blur-sm bg-black/20 transition-colors duration-300">
<div class="max-w-[1440px] mx-auto px-6 lg:px-10 py-4 flex items-center justify-between">
<div class="flex items-center gap-4 text-white">
<div class="size-6 text-primary">
<svg fill="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M12 2L2 19h20L12 2zm0 3.8L18.4 17H5.6L12 5.8z"></path>
<path d="M12 7l-4 7h8l-4-7z" opacity="0.5"></path>
</svg>
</div>
<h2 class="text-white text-xl font-bold tracking-[0.2em] uppercase">LUXE DR</h2>
</div>
<div class="hidden lg:flex items-center gap-8 ml-auto mr-8">
<a class="text-white/80 hover:text-primary transition-colors text-sm font-medium tracking-widest uppercase" href="/elite_vehicle_fleet_gallery" >Fleet</a>
<a class="text-white/80 hover:text-primary transition-colors text-sm font-medium tracking-widest uppercase" href="/vip_services_concierge" >Services</a>
<a class="text-white/80 hover:text-primary transition-colors text-sm font-medium tracking-widest uppercase" href="/contacto_vip" >Concierge</a>
<a class="text-white/80 hover:text-primary transition-colors text-sm font-medium tracking-widest uppercase" href="/contacto_vip" >Membership</a>
</div>
<div class="flex items-center gap-4">
<button class="hidden md:flex text-white hover:text-primary transition-colors">
<span class="material-symbols-outlined">search</span>
</button>
<button class="flex items-center justify-center rounded bg-primary/90 hover:bg-primary text-[#181611] px-5 py-2 text-sm font-bold tracking-wide transition-colors">
                    LOG IN
                </button>
<button class="lg:hidden text-white">
<span class="material-symbols-outlined">menu</span>
</button>
</div>
</div>
</nav>
<!-- Hero Section -->
<div class="relative h-screen min-h-[700px] w-full flex flex-col items-center justify-center overflow-hidden">
<!-- Background Image/Video Placeholder -->
<div class="absolute inset-0 z-0">
<div class="w-full h-full bg-cover bg-center" data-alt="Luxury black SUV parked on a sleek concrete runway next to a private jet at sunset" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBYML2s6RDGwgv22yzCtTZMrv3INoA1EvXyYjP3hSxGZIjfIdydHTr5bxUuPF1spFu_2KnNyP-kGUyqmEVZ-p3KUniQ5lIIQIrmHElBBg4aLfnEjbmTQ_sn1j4GcKhRQs93CnH0M8oljtR1v_1OYxJ5d3JE_wNFLPSDCGsK6Wrd7hgYRNHCUYDXuvb1wiVbF6bqP8eJqDFD75hfMCTgAOBGp-yDM5IkiTsh9aioEu3lQzK9aO0RVPY5otlOh2bnyx4_jrbKZVbrgQuD');">
</div>
<!-- Gradient Overlay for readability -->
<div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/20 to-background-dark"></div>
<div class="absolute inset-0 bg-black/40"></div>
</div>
<!-- Hero Content -->
<div class="relative z-10 flex flex-col items-center text-center px-4 max-w-5xl mt-[-80px]">
<span class="text-primary tracking-[0.3em] text-xs md:text-sm font-bold uppercase mb-6 animate-fade-in-up">
                Dominican Republic VIP Transport
            </span>
<h1 class="text-white text-4xl md:text-6xl lg:text-7xl font-light leading-tight tracking-[-0.02em] mb-6 drop-shadow-lg">
<span class="font-bold">UNCOMPROMISED</span> LUXURY
            </h1>
<p class="text-gray-200 text-base md:text-lg max-w-2xl font-light leading-relaxed mb-10 text-shadow-sm">
                Arrive in power. Explore in style. Experience the pinnacle of automotive engineering tailored for the Caribbean landscape.
            </p>
</div>
<!-- Reservation Bar (Floating) -->
<div class="absolute bottom-10 w-full px-4 lg:px-10 z-20 flex justify-center">
<div class="bg-[#1f1f1f]/80 backdrop-blur-md border border-white/10 p-2 rounded-lg shadow-2xl w-full max-w-5xl">
<form class="flex flex-col lg:flex-row gap-2 lg:items-center">
<!-- Location -->
<div class="flex-1 relative group bg-white/5 hover:bg-white/10 rounded transition-colors p-3 lg:border-r lg:border-white/10 lg:bg-transparent lg:hover:bg-transparent">
<label class="block text-[10px] uppercase tracking-wider text-primary font-bold mb-1">Pick-up Location</label>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-white/50 text-lg">flight_land</span>
<select class="w-full bg-transparent border-none p-0 text-white text-sm focus:ring-0 cursor-pointer">
<option class="bg-[#1f1f1f]">Punta Cana Intl (PUJ)</option>
<option class="bg-[#1f1f1f]">Santo Domingo (SDQ)</option>
<option class="bg-[#1f1f1f]">La Romana (LRM)</option>
<option class="bg-[#1f1f1f]">Casa de Campo</option>
</select>
</div>
</div>
<!-- Drop-off -->
<div class="flex-1 relative group bg-white/5 hover:bg-white/10 rounded transition-colors p-3 lg:border-r lg:border-white/10 lg:bg-transparent lg:hover:bg-transparent">
<label class="block text-[10px] uppercase tracking-wider text-white/60 font-bold mb-1 group-hover:text-primary transition-colors">Drop-off</label>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-white/50 text-lg">flight_takeoff</span>
<select class="w-full bg-transparent border-none p-0 text-white text-sm focus:ring-0 cursor-pointer">
<option class="bg-[#1f1f1f]">Same as Pick-up</option>
<option class="bg-[#1f1f1f]">Different Location</option>
</select>
</div>
</div>
<!-- Dates -->
<div class="flex-1 relative group bg-white/5 hover:bg-white/10 rounded transition-colors p-3 lg:border-r lg:border-white/10 lg:bg-transparent lg:hover:bg-transparent">
<label class="block text-[10px] uppercase tracking-wider text-white/60 font-bold mb-1 group-hover:text-primary transition-colors">Dates</label>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-white/50 text-lg">calendar_month</span>
<input class="w-full bg-transparent border-none p-0 text-white text-sm focus:ring-0 placeholder-white/80" onfocus="(this.type='date')" placeholder="Select Dates" type="text"/>
</div>
</div>
<!-- Vehicle Class -->
<div class="flex-1 relative group bg-white/5 hover:bg-white/10 rounded transition-colors p-3 lg:bg-transparent lg:hover:bg-transparent">
<label class="block text-[10px] uppercase tracking-wider text-white/60 font-bold mb-1 group-hover:text-primary transition-colors">Vehicle Class</label>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-white/50 text-lg">directions_car</span>
<select class="w-full bg-transparent border-none p-0 text-white text-sm focus:ring-0 cursor-pointer">
<option class="bg-[#1f1f1f]">Any Class</option>
<option class="bg-[#1f1f1f]">Luxury SUV</option>
<option class="bg-[#1f1f1f]">Exotic Sport</option>
<option class="bg-[#1f1f1f]">Executive Sedan</option>
<option class="bg-[#1f1f1f]">Armored</option>
</select>
</div>
</div>
<!-- CTA Button -->
<button class="bg-primary hover:bg-[#d4a826] text-[#181611] font-bold text-sm tracking-widest uppercase px-8 py-4 rounded shadow-lg transition-all duration-300 transform hover:scale-[1.02] flex items-center justify-center gap-2 lg:h-full lg:w-auto w-full mt-2 lg:mt-0 whitespace-nowrap" type="button">
<span>Reserve</span>
<span class="material-symbols-outlined text-lg">arrow_forward</span>
</button>
</form>
</div>
</div>
</div>
<!-- Stats Section (Sub-hero) -->
<div class="bg-surface-dark border-b border-white/5">
<div class="max-w-[1440px] mx-auto px-6 py-12 flex flex-wrap justify-between items-center gap-8 text-center md:text-left">
<div class="flex flex-col md:flex-row gap-4 md:gap-12 w-full justify-center opacity-80">
<div class="flex flex-col items-center md:items-start">
<span class="text-3xl font-light text-white">50+</span>
<span class="text-xs uppercase tracking-widest text-primary/80 mt-1">Premium Vehicles</span>
</div>
<div class="w-px h-12 bg-white/10 hidden md:block"></div>
<div class="flex flex-col items-center md:items-start">
<span class="text-3xl font-light text-white">24/7</span>
<span class="text-xs uppercase tracking-widest text-primary/80 mt-1">Concierge Service</span>
</div>
<div class="w-px h-12 bg-white/10 hidden md:block"></div>
<div class="flex flex-col items-center md:items-start">
<span class="text-3xl font-light text-white">100%</span>
<span class="text-xs uppercase tracking-widest text-primary/80 mt-1">Discretion Guaranteed</span>
</div>
</div>
</div>
</div>
<!-- Feature Section: The Elite Fleet -->
<section class="py-20 lg:py-32 relative bg-background-dark">
<div class="max-w-[1440px] mx-auto px-6 lg:px-10">
<div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
<div>
<h2 class="text-primary text-sm font-bold tracking-[0.2em] uppercase mb-4">The Collection</h2>
<h3 class="text-white text-3xl md:text-5xl font-light">The Elite Fleet</h3>
</div>
<a class="group flex items-center gap-2 text-white hover:text-primary transition-colors text-sm font-bold uppercase tracking-widest pb-1 border-b border-transparent hover:border-primary" href="#">
                    View Full Inventory
                    <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">arrow_right_alt</span>
</a>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
<!-- Vehicle Card 1 -->
<div class="group relative bg-surface-dark rounded-lg overflow-hidden border border-white/5 hover:border-primary/30 transition-all duration-500 hover:shadow-2xl hover:shadow-black/50">
<div class="aspect-[16/10] overflow-hidden relative">
<div class="w-full h-full bg-cover bg-center transition-transform duration-700 group-hover:scale-105" data-alt="Front angle view of a black Mercedes-Benz G63 AMG parked on dark pavement" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBZPyzNlgPaxSyr4R47UOoM6N4QQEJLHdfsnM9l445OWGDEzeagSWXcozBY8lNxU_1Pn15tFaBmcXUAENmHT97-oyYzjWK-vUX3m8_wlqVqv0oXsFF7z2pv6ysAPUzM230wuZfha9ga5t3EuaJLcF2TUwmXJFU1GvDoNBJZdgCgKPNYpPfp4lRsqSJzqRoYiQ4emsR8NSqraqsrwy6Prxz7J7TLr0gEnb3LB_e-xA1xkD4V2OrxblUQQUhZY3Qi4j4dA8fV3PFKCy9w');">
</div>
<div class="absolute top-4 right-4 bg-black/60 backdrop-blur px-3 py-1 rounded text-xs text-white font-bold tracking-widest uppercase">SUV</div>
</div>
